# Dependencies
node_modules/
.pnpm-store/

# npm artefacts (le projet est en pnpm — le lockfile est pnpm-lock.yaml)
package-lock.json
yarn.lock

# Build outputs
.next/
out/
dist/
build/
.turbo/

# Env
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Supabase CLI
.supabase/
supabase/.branches/
supabase/.temp/

# Drop folder pour les sources d'assets (photos brutes, etc.) — les versions
# optimisées sont versionnées dans `packages/brand/assets/` après traitement.
/assets/

# Garde-fou : `eas-cli` et `expo` créent un `eas.json` / `app.json` à la
# racine quand on lance la commande depuis le mauvais répertoire. Les vrais
# fichiers vivent dans `apps/mobile/`. On ignore ceux du root pour éviter
# qu'ils soient commités par erreur (mauvais projectId / mauvais bundleId).
/eas.json
/app.json

# Artefacts de build mobile (`eas build --local` produit des IPA/TAR.GZ
# de plusieurs Mo, à NE PAS commiter — passer par EAS / TestFlight / un
# storage externe pour les distribuer).
*.ipa
*.tar.gz
apps/mobile/ios/
apps/mobile/android/

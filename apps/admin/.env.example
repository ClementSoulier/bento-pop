NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_ADMIN_URL=http://localhost:3100

# Projet Supabase MOBILE (Mon Bento Pop). Server-side uniquement —
# la service-role key ne doit JAMAIS être exposée au navigateur.
MOBILE_SUPABASE_URL=
MOBILE_SUPABASE_SERVICE_ROLE_KEY=

# Revalidation on-demand de la landing depuis le BO. Server-only, sinon
# n'importe qui peut purger le cache. La même valeur doit être posée
# côté landing (REVALIDATE_TOKEN).
LANDING_URL=https://bento-pop.com
REVALIDATE_TOKEN=

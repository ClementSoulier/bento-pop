{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["./node_modules/@types"],
    // `bundler` (au lieu du `node` par défaut d'expo/tsconfig.base) permet
    // à TS de résoudre les `exports.*` (subpath exports) déclarés par les
    // packages workspace comme `@bento-pop/supabase-mobile/types`.
    "moduleResolution": "bundler"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "images.d.ts"
  ],
  "exclude": ["node_modules", ".expo", "ios", "android"]
}

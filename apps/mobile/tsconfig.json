{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    // `bundler` (au lieu du `node` par défaut d'expo/tsconfig.base) permet
    // à TS de résoudre les `exports.*` (subpath exports) déclarés par les
    // packages workspace comme `@bento-pop/supabase-mobile/types`.
    "moduleResolution": "bundler"
    // typeRoots NON spécifié intentionnellement : avec `node-linker=hoisted`
    // au root du monorepo, @types/node et @types/react sont au
    // `<monorepo>/node_modules/@types/`, pas dans `apps/mobile/node_modules/`.
    // Le résolveur TS par défaut remonte la chaîne, et `pnpm.overrides`
    // (cf. root package.json) garantit qu'on a une seule version de
    // @types/react alignée sur 18.
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "images.d.ts"
  ],
  "exclude": ["node_modules", ".expo", "ios", "android"]
}

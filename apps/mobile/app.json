{
  "expo": {
    "name": "Mon Bento Pop",
    "slug": "mon-bento-pop",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "bentopop",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#fbbf24",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bentopop.mobile"
    },
    "android": {
      "package": "com.bentopop.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#fbbf24"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

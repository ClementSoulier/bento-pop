EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# TMDb v4 read access token — créer sur https://www.themoviedb.org/settings/api
# Scope `api_read` uniquement (lecture seule). Acceptable côté client pour
# une app non-commerciale d'après les CGU TMDb.
EXPO_PUBLIC_TMDB_TOKEN=<v4-bearer-token>

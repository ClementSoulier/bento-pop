# node-linker=hoisted : pnpm met TOUTES les deps transitives au flat
# `node_modules/` du monorepo (style yarn classic). C'est requis pour
# que Expo / Metro / React Native fonctionnent en monorepo : ces outils
# font énormément de `require()` transitifs (Expo Router require
# @react-navigation/native, react-native-css-interop/jsx-runtime,
# @babel/runtime/helpers, etc.) chacun depuis son propre scope `.pnpm/`.
# Sans hoist, ces require échouent et le bundle Metro plante.
#
# Le risque historique du hoist global (deux versions de @types/react
# qui se confondent) est neutralisé par `pnpm.overrides` du root
# package.json qui pin @types/react à ~18.3.12.
node-linker=hoisted
